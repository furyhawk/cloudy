ENABLE_SPAMASSASSIN=1
ENABLE_CLAMAV=1
ENABLE_POSTGREY=1
ONE_DIR=1
OVERRIDE_HOSTNAME=mail.furyhawk.lol
OVERRIDE_DOMAINNAME=furyhawk.lol
POSTMASTER_ADDRESS=postmaster@mail.furyhawk.lol
PERMIT_DOCKER=network
# Outbound mail relay (recommended when ISP/cloud blocks direct SMTP to Gmail)
# RELAY_HOST=smtp.your-provider.com
# RELAY_PORT=587
# RELAY_USER=your-smtp-username
# RELAY_PASSWORD=your-smtp-password
SSL_TYPE=manual
SSL_CERT_PATH=/tmp/docker-mailserver/ssl/fullchain.pem
SSL_KEY_PATH=/tmp/docker-mailserver/ssl/privkey.pem